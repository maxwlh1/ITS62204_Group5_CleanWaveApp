<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/btnBackDonationPayment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Donation Program Name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"/>

        <View android:layout_width="40dp" android:layout_height="1dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Donation Amount Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Donation Amount:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:paddingEnd="8dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RM "
                android:textColor="#000000"
                android:background="@drawable/ic_launcher_background"
                android:backgroundTint="#FFFFFF"
                android:padding="8dp"
                android:inputType="numberDecimal"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your payment method"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- Payment Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayTNG"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="160dp"
            android:layout_height="60dp"
            android:text="TNG"
            android:textColor="#000000"
            app:strokeColor="#000000"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayCard"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="160dp"
            android:layout_height="60dp"
            android:text="Card"
            android:textColor="#000000"
            app:strokeColor="#000000"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayOnline"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="160dp"
            android:layout_height="60dp"
            android:text="Online Banking"
            android:textColor="#000000"
            app:strokeColor="#000000"
            app:cornerRadius="12dp"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>

    <!-- Final Donate Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDonation"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donate"
            android:textColor="#000000"
            app:strokeColor="#000000"
            app:cornerRadius="20dp"/>
    </LinearLayout>

</LinearLayout>