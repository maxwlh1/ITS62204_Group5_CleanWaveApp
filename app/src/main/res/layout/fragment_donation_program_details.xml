<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/btnBackDonationDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingEnd="16dp"/>

        <TextView
            android:id="@+id/txtDonationDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Donation Program Name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"/>

        <View android:layout_width="40dp" android:layout_height="1dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000"/>

    <!-- Dynamic Photo Section -->
    <ImageView
        android:id="@+id/imgDonationDetailPhoto"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:background="#EAEAEA"
        android:src="@drawable/donation_pic1" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000"/>

    <!-- Dynamic Details Section -->
    <TextView
        android:id="@+id/txtDonationDetailDesc"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Target: RM 0\nRaised: RM 0\n\nProgram Details..."
        android:textColor="#333333"
        android:textSize="16sp"
        android:lineSpacingExtra="8dp"
        android:padding="24dp"/>

    <!-- Donate Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToPayment"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donate"
            android:textColor="#000000"
            app:strokeColor="#000000"
            app:cornerRadius="20dp"/>
    </LinearLayout>

</LinearLayout>