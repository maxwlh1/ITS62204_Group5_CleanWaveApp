<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CleanWave"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUserProfile"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="👤 PROFILE"
                android:textColor="#000000"
                android:textSize="12sp"
                app:cornerRadius="20dp"
                app:strokeColor="#CCCCCC" />

            <!-- Notification Bell -->
            <TextView
                android:id="@+id/btnNotification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="24sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- 2x2 Button Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReport"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="REPORT WATER\nISSUE"
                android:textColor="#000000"
                android:textSize="12sp"
                android:backgroundTint="#F9F9F9"
                app:strokeColor="#DDDDDD"
                app:cornerRadius="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVolunteer"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="VOLUNTEER"
                android:textColor="#000000"
                android:textSize="12sp"
                android:backgroundTint="#F9F9F9"
                app:strokeColor="#DDDDDD"
                app:cornerRadius="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDonation"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="DONATION"
                android:textColor="#000000"
                android:textSize="12sp"
                android:backgroundTint="#F9F9F9"
                app:strokeColor="#DDDDDD"
                app:cornerRadius="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInfo"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="INFO"
                android:textColor="#000000"
                android:textSize="12sp"
                android:backgroundTint="#F9F9F9"
                app:strokeColor="#DDDDDD"
                app:cornerRadius="4dp"/>
        </LinearLayout>

        <!-- Featured Event Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgEventPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:scaleType="centerCrop"
                    android:background="#EAEAEA"
                    android:src="@drawable/volunteer_pic1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="#FDF9FA">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Coastal Beach Cleanup"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- The "more event" clickable link -->
        <TextView
            android:id="@+id/btnMoreEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="more event"
            android:textColor="#0066CC"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Featured Donation Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgDonationPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:scaleType="centerCrop"
                    android:background="#EAEAEA"
                    android:src="@drawable/donation_pic1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="#FDF9FA">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Save The Turtles Fund"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- The "more donation program" clickable link -->
        <TextView
            android:id="@+id/btnMoreDonations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="more donation program"
            android:textColor="#0066CC"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>